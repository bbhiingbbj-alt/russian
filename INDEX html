<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXUS CC ELITE - Premium Free Fire Service | AMEX Cards & QR Payment</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #00ff00;
            --secondary: #ff006e;
            --tertiary: #00ffff;
            --gold: #ffd700;
            --silver: #c0c0c0;
            --amex-blue: #006fcf;
            --bg-dark: #0a0e27;
            --bg-darker: #050814;
            --premium: #1a1a3e;
        }

        body {
            font-family: 'Courier New', monospace;
            background: linear-gradient(135deg, var(--bg-dark) 0%, var(--premium) 50%, var(--bg-darker) 100%);
            color: var(--primary);
            line-height: 1.6;
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* ===== BACKGROUND EFFECTS ===== */
        .matrix-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100vh;
            pointer-events: none;
            z-index: 1;
            overflow: hidden;
        }

        @keyframes matrix-rain {
            0% { transform: translateY(-100%); opacity: 0; }
            10% { opacity: 0.8; }
            90% { opacity: 0.8; }
            100% { transform: translateY(100vh); opacity: 0; }
        }

        .matrix-char {
            position: absolute;
            color: var(--primary);
            opacity: 0.08;
            font-size: 20px;
            animation: matrix-rain linear infinite;
        }

        .scanlines {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100vh;
            pointer-events: none;
            background: repeating-linear-gradient(
                0deg,
                rgba(0, 255, 0, 0.03),
                rgba(0, 255, 0, 0.03) 1px,
                transparent 1px,
                transparent 2px
            );
            animation: scanlines 8s linear infinite;
            z-index: 2;
        }

        @keyframes scanlines {
            0% { transform: translateY(0); }
            100% { transform: translateY(10px); }
        }

        @keyframes float-orb {
            0%, 100% { transform: translateY(0px) translateX(0px); }
            50% { transform: translateY(-30px) translateX(20px); }
        }

        .orb {
            position: fixed;
            border-radius: 50%;
            pointer-events: none;
            filter: blur(40px);
            z-index: 0;
            animation: float-orb 8s ease-in-out infinite;
        }

        .orb-1 {
            width: 300px;
            height: 300px;
            background: rgba(0, 255, 0, 0.15);
            top: 10%;
            left: 10%;
        }

        .orb-2 {
            width: 400px;
            height: 400px;
            background: rgba(255, 0, 110, 0.1);
            top: 50%;
            right: 5%;
            animation-delay: 3s;
        }

        .orb-3 {
            width: 350px;
            height: 350px;
            background: rgba(0, 255, 255, 0.08);
            bottom: 10%;
            left: 50%;
            animation-delay: 5s;
        }

        .cursor {
            width: 20px;
            height: 20px;
            border: 2px solid var(--primary);
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            box-shadow: 0 0 10px var(--primary);
            z-index: 9999;
        }

        .cursor::after {
            content: '';
            position: absolute;
            width: 8px;
            height: 8px;
            background: var(--secondary);
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        .container {
            position: relative;
            z-index: 3;
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }

        /* ===== HEADER ===== */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 30px;
            border-bottom: 2px solid var(--primary);
            margin-bottom: 50px;
            animation: slideDown 0.8s ease-out;
            box-shadow: 0 0 40px rgba(0, 255, 0, 0.3);
            position: relative;
            z-index: 100;
            background: rgba(10, 14, 39, 0.5);
            backdrop-filter: blur(10px);
            border-radius: 10px;
        }

        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .logo {
            font-size: 32px;
            font-weight: bold;
            text-shadow: 0 0 20px var(--primary), 0 0 40px var(--secondary), 0 0 60px var(--gold);
            animation: pulse-premium 2s ease-in-out infinite;
            cursor: pointer;
            letter-spacing: 2px;
        }

        @keyframes pulse-premium {
            0%, 100% { 
                text-shadow: 0 0 20px var(--primary), 0 0 40px var(--secondary);
                transform: scale(1);
            }
            50% { 
                text-shadow: 0 0 30px var(--primary), 0 0 50px var(--secondary), 0 0 80px var(--gold);
                transform: scale(1.05);
            }
        }

        .premium-badge {
            display: inline-block;
            padding: 5px 15px;
            background: linear-gradient(45deg, var(--gold), var(--silver));
            color: #000;
            border-radius: 20px;
            font-size: 10px;
            font-weight: bold;
            margin-left: 15px;
            animation: badge-glow 1.5s ease-in-out infinite;
        }

        @keyframes badge-glow {
            0%, 100% { box-shadow: 0 0 10px var(--gold); }
            50% { box-shadow: 0 0 20px var(--gold), 0 0 30px var(--secondary); }
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 30px;
        }

        nav a {
            color: var(--primary);
            text-decoration: none;
            font-size: 14px;
            position: relative;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        nav a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--gold), var(--secondary));
            transition: width 0.3s ease;
        }

        nav a:hover::after { width: 100%; }
        nav a:hover {
            text-shadow: 0 0 15px var(--secondary);
            color: var(--gold);
        }

        .cart-icon {
            font-size: 24px;
            cursor: pointer;
            position: relative;
            transition: all 0.3s;
            filter: drop-shadow(0 0 8px var(--gold));
        }

        .cart-count {
            position: absolute;
            top: -8px;
            right: -12px;
            background: linear-gradient(45deg, var(--gold), var(--secondary));
            color: black;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: bold;
        }

        .cart-icon:hover {
            transform: scale(1.2) rotate(15deg);
            filter: drop-shadow(0 0 15px var(--gold));
        }

        /* ===== HERO SECTION ===== */
        .hero {
            text-align: center;
            margin: 100px 0;
            animation: fadeInUp 1s ease-out;
            position: relative;
            z-index: 10;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .hero h1 {
            font-size: 72px;
            margin-bottom: 20px;
            background: linear-gradient(45deg, var(--gold), var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: glitch 0.3s infinite;
            letter-spacing: 3px;
            filter: drop-shadow(0 0 30px rgba(255, 215, 0, 0.5));
        }

        @keyframes glitch {
            0% { transform: translate(0); }
            20% { transform: translate(-2px, 2px); }
            40% { transform: translate(-2px, -2px); }
            60% { transform: translate(2px, 2px); }
            80% { transform: translate(2px, -2px); }
            100% { transform: translate(0); }
        }

        .hero p {
            font-size: 20px;
            color: var(--tertiary);
            margin-bottom: 40px;
            text-shadow: 0 0 20px var(--tertiary);
            letter-spacing: 1px;
        }

        .cta-btn {
            display: inline-block;
            padding: 15px 50px;
            background: linear-gradient(45deg, var(--gold), var(--secondary), var(--primary));
            color: #000;
            text-decoration: none;
            font-weight: bold;
            border: 2px solid var(--gold);
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            font-size: 14px;
            box-shadow: 0 0 30px rgba(255, 215, 0, 0.6), inset 0 0 20px rgba(255, 215, 0, 0.2);
            animation: slideIn 1.2s ease-out;
            letter-spacing: 2px;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateX(-50px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .cta-btn:hover {
            box-shadow: 0 0 60px rgba(255, 215, 0, 0.8), 0 0 80px rgba(255, 0, 110, 0.8), inset 0 0 30px rgba(255, 215, 0, 0.3);
            transform: scale(1.08);
        }

        /* ===== SECTION TITLES ===== */
        .section-title {
            font-size: 48px;
            margin: 50px 0 50px 0;
            text-align: center;
            background: linear-gradient(45deg, var(--gold), var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            border-bottom: 3px solid var(--gold);
            padding-bottom: 20px;
            animation: titleGlow 2s ease-in-out infinite;
            letter-spacing: 2px;
        }

        @keyframes titleGlow {
            0%, 100% { filter: drop-shadow(0 0 10px var(--gold)); }
            50% { filter: drop-shadow(0 0 30px var(--gold)) drop-shadow(0 0 40px var(--secondary)); }
        }

        /* ===== QR UPLOAD SECTION ===== */
        .qr-upload-section {
            background: rgba(26, 26, 62, 0.4);
            backdrop-filter: blur(20px);
            border: 3px dashed var(--gold);
            padding: 40px;
            border-radius: 15px;
            text-align: center;
            margin-bottom: 50px;
            position: relative;
            z-index: 10;
            animation: fadeInUp 1s ease-out;
        }

        .qr-upload-section h3 {
            color: var(--gold);
            font-size: 24px;
            margin-bottom: 20px;
            text-shadow: 0 0 15px var(--gold);
        }

        .upload-area {
            border: 2px dashed var(--gold);
            padding: 30px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s;
            background: rgba(0, 255, 0, 0.03);
        }

        .upload-area:hover {
            background: rgba(0, 255, 0, 0.08);
            border-color: var(--secondary);
            transform: scale(1.02);
        }

        .upload-area.dragover {
            background: rgba(255, 0, 110, 0.15);
            border-color: var(--secondary);
            transform: scale(1.05);
        }

        .upload-area p {
            color: var(--primary);
            font-size: 16px;
            margin-bottom: 10px;
        }

        #qrFileInput {
            display: none;
        }

        .upload-btn {
            display: inline-block;
            padding: 12px 30px;
            background: linear-gradient(45deg, var(--gold), var(--secondary));
            color: #000;
            border: 2px solid var(--gold);
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            border-radius: 8px;
            font-size: 12px;
            letter-spacing: 1px;
            box-shadow: 0 0 20px rgba(255, 215, 0, 0.4);
            margin-top: 15px;
            font-family: 'Courier New', monospace;
        }

        .upload-btn:hover {
            box-shadow: 0 0 40px rgba(255, 215, 0, 0.8);
            transform: scale(1.05);
        }

        .qr-preview {
            margin-top: 20px;
            display: none;
        }

        .qr-preview img {
            max-width: 200px;
            max-height: 200px;
            border-radius: 10px;
            box-shadow: 0 0 30px rgba(255, 215, 0, 0.4);
        }

        .qr-status {
            color: var(--primary);
            margin-top: 15px;
            font-size: 14px;
            text-shadow: 0 0 10px var(--primary);
        }

        .qr-status.success {
            color: var(--primary);
        }

        /* ===== AMEX CARDS SECTION ===== */
        .cards-section {
            margin: 80px 0;
            position: relative;
            z-index: 10;
        }

        .cards-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 40px;
            margin: 50px 0;
        }

        .amex-card {
            perspective: 1000px;
            height: 250px;
            cursor: pointer;
            animation: cardSlideIn 0.8s ease-out forwards;
            opacity: 0;
        }

        @keyframes cardSlideIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .amex-card:nth-child(1) { animation-delay: 0.1s; }
        .amex-card:nth-child(2) { animation-delay: 0.2s; }

        .card-inner {
            position: relative;
            width: 100%;
            height: 100%;
            transition: transform 0.6s;
            transform-style: preserve-3d;
        }

        .amex-card:hover .card-inner {
            transform: rotateY(180deg);
        }

        .card-front, .card-back {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 20px 60px rgba(0, 111, 207, 0.4);
        }

        .card-front {
            background: linear-gradient(135deg, var(--amex-blue) 0%, #004fa3 100%);
            border: 2px solid rgba(255, 215, 0, 0.3);
            color: white;
            font-weight: bold;
        }

        .card-front::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(0, 255, 0, 0.05) 0%, transparent 50%);
            border-radius: 15px;
            pointer-events: none;
        }

        .card-back {
            background: linear-gradient(135deg, #004fa3 0%, var(--amex-blue) 100%);
            transform: rotateY(180deg);
            border: 2px solid rgba(255, 215, 0, 0.3);
            color: white;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .amex-logo {
            font-size: 32px;
            margin-bottom: 15px;
            filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.3));
        }

        .card-number {
            font-size: 24px;
            letter-spacing: 2px;
            margin-bottom: 15px;
            text-shadow: 0 0 10px rgba(0, 0, 0, 0.3);
        }

        .card-holder-info {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            font-size: 12px;
        }

        .card-holder-name {
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .card-expiry {
            text-align: right;
        }

        .card-cvv {
            background: rgba(0, 0, 0, 0.3);
            padding: 8px 15px;
            border-radius: 5px;
            font-size: 14px;
            margin-bottom: 10px;
        }

        .card-details {
            background: rgba(0, 0, 0, 0.2);
            padding: 15px;
            border-radius: 8px;
            font-size: 13px;
            line-height: 1.8;
        }

        .card-balance {
            font-size: 18px;
            font-weight: bold;
            margin-top: 10px;
            color: var(--gold);
            text-shadow: 0 0 10px var(--gold);
        }

        .card-title {
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 8px;
            color: var(--gold);
            text-shadow: 0 0 8px var(--gold);
        }

        .card-price {
            font-size: 24px;
            font-weight: bold;
            color: white;
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.6);
            margin: 10px 0;
        }

        .card-limit {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.8);
            margin-bottom: 15px;
        }

        .buy-btn {
            width: 100%;
            padding: 12px;
            background: linear-gradient(45deg, var(--gold), var(--secondary));
            color: #000;
            border: 2px solid var(--gold);
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            border-radius: 8px;
            font-size: 12px;
            letter-spacing: 1px;
            box-shadow: 0 0 20px rgba(255, 215, 0, 0.4);
            margin-top: 15px;
            font-family: 'Courier New', monospace;
            position: relative;
            z-index: 50;
        }

        .buy-btn:hover {
            box-shadow: 0 0 40px rgba(255, 215, 0, 0.8), 0 0 60px rgba(255, 0, 110, 0.6);
            transform: scale(1.05);
        }

        .buy-btn:active {
            transform: scale(0.98);
        }

        /* ===== PRODUCTS SECTION ===== */
        .products {
            margin: 100px 0;
            animation: fadeIn 1.5s ease-out;
            position: relative;
            z-index: 10;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-bottom: 50px;
        }

        .product-card {
            background: rgba(26, 26, 62, 0.4);
            backdrop-filter: blur(20px);
            border: 2px solid rgba(255, 215, 0, 0.3);
            padding: 30px;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            overflow: hidden;
            animation: cardSlideIn 0.8s ease-out forwards;
            opacity: 0;
            border-radius: 15px;
            box-shadow: 
                0 8px 32px rgba(31, 38, 135, 0.37),
                inset 0 0 20px rgba(255, 215, 0, 0.05);
        }

        .product-card:nth-child(1) { animation-delay: 0.1s; }
        .product-card:nth-child(2) { animation-delay: 0.2s; }
        .product-card:nth-child(3) { animation-delay: 0.3s; }
        .product-card:nth-child(4) { animation-delay: 0.4s; }
        .product-card:nth-child(5) { animation-delay: 0.5s; }
        .product-card:nth-child(6) { animation-delay: 0.6s; }

        .product-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(255, 215, 0, 0.2), transparent);
            animation: shimmer 3s infinite;
            transform: rotate(45deg);
        }

        @keyframes shimmer {
            0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
            100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
        }

        .product-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 215, 0, 0.15), transparent);
            transition: left 0.5s;
        }

        .product-card:hover::after { left: 100%; }

        .product-card:hover {
            border-color: var(--gold);
            box-shadow: 
                0 20px 60px rgba(255, 215, 0, 0.4),
                inset 0 0 30px rgba(255, 215, 0, 0.15),
                0 0 50px rgba(255, 0, 110, 0.3);
            transform: translateY(-15px) scale(1.05);
            background: rgba(26, 26, 62, 0.6);
        }

        .product-badge {
            position: absolute;
            top: -10px;
            right: -10px;
            padding: 8px 20px;
            background: linear-gradient(45deg, var(--gold), var(--secondary));
            color: #000;
            border-radius: 50px;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
            animation: badgeBounce 2s ease-in-out infinite;
            box-shadow: 0 0 20px var(--gold);
            z-index: 10;
        }

        @keyframes badgeBounce {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-10px) rotate(5deg); }
        }

        .product-icon {
            font-size: 56px;
            margin-bottom: 20px;
            animation: iconBounce 2s ease-in-out infinite;
            filter: drop-shadow(0 0 10px var(--gold));
        }

        @keyframes iconBounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-15px); }
        }

        .product-card:hover .product-icon {
            animation: spin 0.6s linear;
            filter: drop-shadow(0 0 20px var(--gold)) drop-shadow(0 0 30px var(--secondary));
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .product-name {
            font-size: 24px;
            margin-bottom: 10px;
            color: var(--gold);
            text-shadow: 0 0 15px var(--gold);
            letter-spacing: 1px;
            font-weight: bold;
        }

        .product-price {
            font-size: 28px;
            font-weight: bold;
            color: var(--gold);
            text-shadow: 0 0 15px var(--gold);
            margin-bottom: 15px;
            letter-spacing: 1px;
        }

        .price-tag {
            font-size: 12px;
            color: var(--secondary);
            text-decoration: line-through;
            opacity: 0.7;
        }

        .add-to-cart-btn {
            width: 100%;
            padding: 14px;
            background: linear-gradient(45deg, var(--gold), var(--secondary));
            color: #000;
            border: 2px solid var(--gold);
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            font-family: 'Courier New', monospace;
            font-size: 13px;
            border-radius: 8px;
            box-shadow: 0 0 20px rgba(255, 215, 0, 0.4);
            letter-spacing: 1px;
            position: relative;
            z-index: 5;
        }

        .add-to-cart-btn:hover {
            background: linear-gradient(45deg, var(--secondary), var(--gold));
            box-shadow: 0 0 40px var(--gold), 0 0 60px var(--secondary);
            transform: scale(1.05);
        }

        /* ===== FEATURES SECTION ===== */
        .features {
            margin: 100px 0;
            position: relative;
            z-index: 10;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        .feature-box {
            background: rgba(26, 26, 62, 0.4);
            backdrop-filter: blur(20px);
            border-left: 6px solid var(--gold);
            padding: 30px;
            transition: all 0.3s;
            animation: featureSlide 0.8s ease-out forwards;
            opacity: 0;
            border-radius: 10px;
            box-shadow: 0 8px 32px rgba(31, 38, 135, 0.37);
        }

        @keyframes featureSlide {
            from { opacity: 0; transform: translateX(-30px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .feature-box:nth-child(1) { animation-delay: 0.1s; }
