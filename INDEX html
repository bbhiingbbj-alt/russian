            </div>
            <p>&copy; 2026 NEXUS ELITE CC | Premium Free Fire Service Provider</p>
            <p style="font-size: 12px; color: var(--gold); margin-top: 10px;">[ PREMIUM_ACTIVE ] [ SECURITY_VERIFIED ] [ ZERO_BANS_GUARANTEE ]</p>
        </footer>
    </div>

    <!-- QR Code Modal -->
    <div class="qr-modal" id="qrModal">
        <div class="qr-content">
            <div class="qr-header">🔐 PAYMENT QR CODE</div>
            <div class="qr-subtitle">Scan with your payment app to complete payment</div>
            <div class="qr-amount" id="qrAmount">Amount: ₹2,000</div>
            <div class="qr-image-container">
                <img id="qrcodeDisplay" src="" alt="QR Code" />
            </div>
            <div class="qr-timer">⏱️ Expires in: <span id="timerCount">120</span>s</div>
            <div class="qr-close-hint">Click outside or wait for expiration to close</div>
        </div>
    </div>

    <!-- Shopping Cart Modal -->
    <div class="cart-modal" id="cartModal">
        <div class="cart-content">
            <div class="cart-header">
                <h2>PREMIUM CART</h2>
                <span class="cart-close" onclick="toggleCart()">✕</span>
            </div>
            <div class="cart-items" id="cartItems"></div>
            <div class="cart-footer">
                <div class="cart-total">TOTAL: ₹<span id="cartTotal">0</span></div>
                <button class="checkout-btn" onclick="checkout()">>>> PROCESS PAYMENT NOW</button>
            </div>
        </div>
    </div>

    <script>
        let uploadedQRImage = null;
        let qrTimer = null;

        // Premium Products Data with INR
        const products = [
            {
                id: 1,
                name: 'LEGENDARY SKIN',
                icon: '👑',
                price: 499,
                oldPrice: 699
            },
            {
                id: 2,
                name: 'MYSTIC WEAPON',
                icon: '⚔️',
                price: 299,
                oldPrice: 499
            },
            {
                id: 3,
                name: 'DELUXE BUNDLE',
                icon: '🎁',
                price: 799,
                oldPrice: 1299
            },
            {
                id: 4,
                name: 'ELITE PASS',
                icon: '🏆',
                price: 1299,
                oldPrice: 1999
            },
            {
                id: 5,
                name: 'PLATINUM EMOTES',
                icon: '💎',
                price: 249,
                oldPrice: 499
            },
            {
                id: 6,
                name: 'MYSTERY BOX',
                icon: '🎲',
                price: 199,
                oldPrice: 399
            }
        ];

        const testimonials = [
            {
                text: 'Best premium service ever! Got everything instantly. Absolutely worth it!',
                author: 'ElitePlayer#001',
                stars: 5
            },
            {
                text: 'Premium support is incredible. They solved my issue in under 2 minutes!',
                author: 'ProGamer#FF',
                stars: 5
            },
            {
                text: 'Using NEXUS for months now. Zero issues, amazing prices, highly recommend!',
                author: 'VIPMember#2026',
                stars: 5
            }
        ];

        let cart = [];

        // Matrix Animation
        function createMatrixChar() {
            const chars = '01अइउएओकखगघचछजझञटठडढणतथदधनपफबभमयरलवशषसह';
            const char = chars[Math.floor(Math.random() * chars.length)];
            const matrixBg = document.getElementById('matrixBg');
            const div = document.createElement('div');
            div.className = 'matrix-char';
            div.textContent = char;
            div.style.left = Math.random() * 100 + '%';
            div.style.top = '-50px';
            div.style.animationDuration = (Math.random() * 10 + 10) + 's';
            matrixBg.appendChild(div);
            setTimeout(() => div.remove(), 15000);
        }
        setInterval(createMatrixChar, 300);

        // Custom Cursor
        const cursor = document.getElementById('cursor');
        document.addEventListener('mousemove', (e) => {
            cursor.style.left = e.clientX - 10 + 'px';
            cursor.style.top = e.clientY - 10 + 'px';
        });

        // QR FILE UPLOAD HANDLING
        const uploadArea = document.getElementById('uploadArea');
        const qrFileInput = document.getElementById('qrFileInput');

        uploadArea.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadArea.classList.add('dragover');
        });

        uploadArea.addEventListener('dragleave', () => {
            uploadArea.classList.remove('dragover');
        });

        uploadArea.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadArea.classList.remove('dragover');
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                handleQRUpload(files[0]);
            }
        });

        qrFileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                handleQRUpload(e.target.files[0]);
            }
        });

        function handleQRUpload(file) {
            if (!file.type.startsWith('image/')) {
                showNotification('❌ Please upload an image file');
                return;
            }

            if (file.size > 5 * 1024 * 1024) {
                showNotification('❌ File size must be less than 5MB');
                return;
            }

            const reader = new FileReader();
            reader.onload = (e) => {
                uploadedQRImage = e.target.result;
                document.getElementById('qrPreviewImg').src = uploadedQRImage;
                document.getElementById('qrPreview').style.display = 'block';
                showNotification('✅ QR image loaded! Click confirm to save');
            };
            reader.readAsDataURL(file);
        }

        function uploadQR() {
            if (!uploadedQRImage) {
                showNotification('❌ Please upload a QR code image first');
                return;
            }
            showNotification('✅ QR code set successfully! Ready for payment');
        }

        // Show QR Code
        function showQRCode(amount, cardType) {
            if (!uploadedQRImage) {
                showNotification('⚠️ Please upload QR code in the QR section first');
                return;
            }

            const modal = document.getElementById('qrModal');
            const qrcodeDisplay = document.getElementById('qrcodeDisplay');
            
            qrcodeDisplay.src = uploadedQRImage;
            
            document.getElementById('qrAmount').textContent = `Amount: ₹${amount}`;
            modal.style.display = 'flex';
            
            startQRTimer();
            showNotification(`💳 QR Code displayed for ₹${amount} ${cardType} card!`);
        }

        function startQRTimer() {
            let timeLeft = 120;
            document.getElementById('timerCount').textContent = timeLeft;
            
            if (qrTimer) clearInterval(qrTimer);
            
            qrTimer = setInterval(() => {
                timeLeft--;
                document.getElementById('timerCount').textContent = timeLeft;
                
                if (timeLeft <= 0) {
                    clearInterval(qrTimer);
                    closeQRModal();
                }
            }, 1000);
        }

        function closeQRModal() {
            const modal = document.getElementById('qrModal');
            modal.style.display = 'none';
            if (qrTimer) clearInterval(qrTimer);
            showNotification('✅ QR Code expired! Payment window closed');
        }

        document.getElementById('qrModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeQRModal();
            }
        });

        // Render Products
        function renderProducts() {
            const grid = document.getElementById('productsGrid');
            grid.innerHTML = products.map(product => `
                <div class="product-card">
                    <div class="product-badge">💎 LIMITED</div>
                    <div class="product-icon">${product.icon}</div>
                    <div class="product-name">${product.name}</div>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                        <div class="product-price">₹${product.price}</div>
                        <span class="price-tag">₹${product.oldPrice}</span>
                    </div>
                    <button class="add-to-cart-btn" onclick="addToCart(${product.id})">>>> ADD TO CART</button>
                </div>
            `).join('');
        }

        // Render Testimonials
        function renderTestimonials() {
            const grid = document.getElementById('testimonialsGrid');
            grid.innerHTML = testimonials.map(testimonial => `
                <div class="testimonial-card">
                    <div class="stars">${'⭐'.repeat(testimonial.stars)}</div>
                    <div class="testimonial-text">"${testimonial.text}"</div>
                    <div class="testimonial-author">- ${testimonial.author}</div>
                </div>
            `).join('');
        }

        // Cart Functions
        function addToCart(productId) {
            const product = products.find(p => p.id === productId);
            cart.push(product);
            updateCart();
            showNotification(`${product.name} added to premium cart!`);
        }

        function removeFromCart(index) {
            cart.splice(index, 1);
            updateCart();
        }

        function updateCart() {
            document.getElementById('cartCount').textContent = cart.length;
            renderCartItems();
            updateCartTotal();
        }

        function renderCartItems() {
            const cartItemsDiv = document.getElementById('cartItems');
            if (cart.length === 0) {
                cartItemsDiv.innerHTML = '<p style="text-align: center; color: var(--gold); padding: 40px 20px; font-size: 14px;">Your premium cart is empty</p>';
                return;
            }
            cartItemsDiv.innerHTML = cart.map((item, index) => `
                <div class="cart-item">
                    <div class="cart-item-info">
                        <div class="cart-item-name">${item.name}</div>
                        <div class="cart-item-price">₹${item.price}</div>
                    </div>
                    <button class="remove-btn" onclick="removeFromCart(${index})">Remove</button>
                </div>
            `).join('');
        }

        function updateCartTotal() {
            const total = cart.reduce((sum, item) => sum + item.price, 0);
            document.getElementById('cartTotal').textContent = total;
        }

        function toggleCart() {
            const modal = document.getElementById('cartModal');
            modal.style.display = modal.style.display === 'none' ? 'flex' : 'none';
        }

        function checkout() {
            if (cart.length === 0) {
                alert('Your premium cart is empty!');
                return;
            }
            const total = cart.reduce((sum, item) => sum + item.price, 0);
            alert(`💳 Processing premium payment: ₹${total}\n\n✅ Thank you for your premium purchase!\n📧 Check your email for order confirmation & delivery details.`);
            cart = [];
            updateCart();
            toggleCart();
        }

        function handleSubmit(event) {
            event.preventDefault();
            showNotification(`✅ Message received! Our elite support will contact you soon.`);
            event.target.reset();
        }

        function showNotification(text) {
            const notification = document.createElement('div');
            notification.className = 'notification';
            notification.textContent = text;
            document.body.appendChild(notification);
            setTimeout(() => notification.remove(), 3000);
        }

        // Initialize
        window.addEventListener('load', () => {
            renderProducts();
            renderTestimonials();
            updateCart();
        });
    </script>
</body>
</html>
